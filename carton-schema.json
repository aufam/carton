{
  "$schema": "http://json-schema.org/draft-07/schema#",

  "$defs": {
    "profile": {
      "type": "object",
      "properties": {
        "id": { "type": "string" },
        "cpp": { "type": "string" },
        "c": { "type": "string" }
      }
    },

    "package": {
      "type": "object",
      "required": ["name"],
      "properties": {
        "name": { "type": "string" },
        "version": {
          "type": "string",
          "pattern": "^\\d+\\.\\d+\\.\\d+"
        },
        "edition": {
          "type": "integer",
          "enum": [11, 14, 17, 20, 23, 26],
          "default": 17
        },
        "authors": {
          "type": "array",
          "items": { "type": "string" }
        },
        "description": { "type": "string" },
        "license": { "type": "string" },
        "readme": { "type": "string" },
        "repository": { "type": "string" },
        "homepage": { "type": "string" },
        "documentation": { "type": "string" },
      }
    },

    "sourceSpec": {
      "type": "object",
      "properties": {
        "version": { "type": "string" },
        "path": { "type": "string" },
        "url": { "type": "string" },
        "git": { "type": "string" },
        "tag": { "type": "string" },
        "branch": { "type": "string" },
        "subdir": { "type": "string" },
        "features": { "type": "array", "items": { "type": "string" } },
        "optional": { "type": "boolean", "default": false },
        "default-features": { "type": "boolean", "default": true },
        "src": { "type": "array", "items": { "type": "string" } },
        "inc": { "type": "array", "items": { "type": "string" } },
        "lib": { "type": "array", "items": { "type": "string" } },
        "mod": { "type": "array", "items": { "type": "string" } },
        "flags": { "type": "array", "items": { "type": "string" } },
        "link-flags": { "type": "array", "items": { "type": "string" } },
        "pre": { "type": "string" }
      },
      "oneOf": [
        {
          "required": ["path"],
          "not": {
            "anyOf": [
              { "required": ["url"] },
              { "required": ["git"] }
            ]
          }
        },
        {
          "required": ["url"],
          "not": {
            "anyOf": [
              { "required": ["path"] },
              { "required": ["git"] },
              { "required": ["tag"] },
              { "required": ["branch"] }
            ]
          }
        },
        {
          "required": ["git"],
          "not": {
            "required": ["path"]
          },
          "anyOf": [
            { "required": ["tag"] },
            { "required": ["branch"] }
          ]
        }
      ]
    },

    "dependency": {
      "oneOf": [
        { "type": "string" },
        { "$ref": "#/$defs/sourceSpec" }
      ]
    }
  },

  "type": "object",
  "properties": {
    "profiles": {
      "type": "object",
      "properties": {
        "release": { "$ref": "#/$defs/profile" },
        "debug": { "$ref": "#/$defs/profile" }
      }
    },

    "package": { "$ref": "#/$defs/package" },

    "lib": { "$ref": "#/$defs/dependency" },

    "dependencies": {
      "type": "object",
      "additionalProperties": { "$ref": "#/$defs/dependency" }
    },

    "features": {
      "type": "object",
      "additionalProperties": {
        "type": "array",
        "items": { "type": "string" }
      }
    },

    "vars": { "type": "object", "additionalProperties": { "type": "string" } }
  }
}
